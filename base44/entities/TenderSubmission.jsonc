{
  "name": "TenderSubmission",
  "type": "object",
  "properties": {
    "tender_id": {
      "type": "string",
      "description": "ID of the owning Tender"
    },
    "invitee_id": {
      "type": "string",
      "description": "ID of the TenderInvitee record"
    },
    "invitation_id": {
      "type": "string",
      "description": "ID of the TenderInvitation record"
    },
    "invitee_name": {
      "type": "string"
    },
    "full_name": {
      "type": "string",
      "description": "Snapshot of invitee full name at time of submission"
    },
    "invitee_email": {
      "type": "string"
    },
    "business_name": {
      "type": "string",
      "description": "Snapshot of invitee business name at time of submission"
    },
    "trade": {
      "type": "string",
      "description": "Snapshot of invitee trade at time of submission"
    },
    "lump_sum_price": {
      "type": "number"
    },
    "notes": {
      "type": "string"
    },
    "uploaded_file_url": {
      "type": "string"
    },
    "uploaded_file_name": {
      "type": "string"
    },
    "price_breakdown": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "trade_package": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          }
        }
      }
    },
    "submitted_at": {
      "type": "string"
    },
    "scores": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "criterion": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "comment": {
            "type": "string"
          }
        }
      }
    },
    "outcome": {
      "type": "string",
      "enum": [
        "",
        "Awarded",
        "Unsuccessful"
      ],
      "default": ""
    },
    "outcome_notes": {
      "type": "string"
    },
    "outcome_notified_at": {
      "type": "string",
      "description": "ISO datetime when outcome notification was successfully sent"
    },
    "outcome_notification_status": {
      "type": "string",
      "enum": [
        "",
        "Pending",
        "Sent",
        "Failed"
      ],
      "default": "",
      "description": "Status of the outcome notification send attempt"
    },
    "outcome_notification_type": {
      "type": "string",
      "enum": [
        "",
        "Awarded",
        "Unsuccessful"
      ],
      "default": "",
      "description": "Type of notification sent"
    },
    "outcome_notification_message_id": {
      "type": "string",
      "description": "Resend message ID confirming delivery"
    },
    "outcome_notification_error": {
      "type": "string",
      "description": "Error message if notification failed"
    }
  },
  "required": [
    "tender_id"
  ],
  "rls": {
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "pricing"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "pricing"
          }
        }
      ]
    }
  }
}